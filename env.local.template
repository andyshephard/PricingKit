# COPY TO .env.local AND FILL IN THE VALUES

# Apple App Store Connect Credentials
# Get these from: https://appstoreconnect.apple.com/access/api
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----"
APPLE_KEY_ID="YOUR_KEY_ID"
APPLE_ISSUER_ID="YOUR_ISSUER_ID"
APPLE_BUNDLE_ID="com.your.app.bundle.id"

# Open Exchange Rates API Key
# Get it from: https://openexchangerates.org/signup/free
OPEN_EXCHANGE_RATES_APP_ID="YOUR_OPEN_EXCHANGE_RATES_APP_ID"

# Encryption Key for session cookies (Required for production, optional for local dev)
# Generate a random 32+ character string
ENCRYPTION_KEY="your-random-32-character-encryption-key-here"
